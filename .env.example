SUPERMEMORY_API_KEY=

# ── Local Scripts ─────────────────────────────────────────────────────
# Only needed if downloading datasets from Roboflow (fallback when no
# dataset is already uploaded to the Modal volume).
# ROBOFLOW_API_KEY=

# ── Dev client (scripts/e2e_webcam_demo.py) ──────────────────────────
# MODAL_WS_URL=wss://gitbolt--dronecat-web.modal.run/ws

# ── Picam integration (Raspberry Pi camera) ──────────────────────────
# PICAM_URL=https://xxx.trycloudflare.com
# FRAME_INTERVAL=0.2
# INSPECTION_MODE=general

# ── Modal Secrets ────────────────────────────────────────────────────
# These are NOT loaded from .env — they live in Modal secrets.
# Create with:
#   modal secret create catwatch-db DATABASE_URL=postgresql://... DASHBOARD_URL=https://catwatch.vercel.app
