SUPERMEMORY_API_KEY=
ROBOFLOW_API_KEY=

# ── Web Dashboard (web/.env) ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:...@postgres.railway.internal:5432/railway
NEXTAUTH_SECRET=<random-secret>
NEXTAUTH_URL=https://catwatch.vercel.app
RESEND_API_KEY=re_...

# ── Modal Secrets (catwatch-db) ───────────────────────────────────────
# DATABASE_URL=<same Railway URL, external hostname>
# DASHBOARD_URL=https://catwatch.vercel.app

# ── Frontend env (web/.env.local) ─────────────────────────────────────
NEXT_PUBLIC_BACKEND_WS=wss://gitbolt--dronecat-web.modal.run