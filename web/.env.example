DATABASE_URL=postgresql://user:pass@host:5432/railway

# MAGIC_SECRET_KEY is server-side only
MAGIC_SECRET_KEY=sk_live_...

NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=pk_live_...

# Used to store and retrieve findings across sessions for the same unit or site
SUPERMEMORY_API_KEY=sm_...

# OpenAI — used by /api/generate-claim to produce AI-written insurance claim documents
OPENAI_API_KEY=sk-...

# Backend WebSocket URL — only needed if you deployed your own Modal backend
# Defaults to the production URL hardcoded in use-session-socket.ts
# NEXT_PUBLIC_BACKEND_WS=wss://your-modal-app.modal.run
