# Database (Railway PostgreSQL — also set in Modal secret "catwatch-db")
DATABASE_URL=postgresql://user:pass@host:5432/railway

# Magic Link auth (from dashboard.magic.link)
MAGIC_SECRET_KEY=sk_live_...
NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY=pk_live_...

# Supermemory (inspection knowledge base)
SUPERMEMORY_API_KEY=sm_...

# Backend WebSocket URL (optional — defaults to wss://gitbolt--dronecat-web.modal.run)
# NEXT_PUBLIC_BACKEND_WS=wss://gitbolt--dronecat-web.modal.run
